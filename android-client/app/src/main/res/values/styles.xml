<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="AppTheme" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <!-- Customize your theme here. -->
        <item name="colorPrimary">@color/racing_red</item>
        <item name="colorPrimaryDark">@color/racing_carbon</item>
        <item name="colorAccent">@color/racing_accent_yellow</item>
        <item name="android:windowBackground">@color/racing_black</item>
        <item name="android:windowFullscreen">true</item>
        <item name="android:windowNoTitle">true</item>

        <!-- Splash Screen (Android 12+) -->
        <item name="android:windowSplashScreenAnimatedIcon" tools:targetApi="s">@drawable/app_logo</item>
        <item name="android:windowSplashScreenBackground" tools:targetApi="s">@color/racing_black</item>
    </style>

    <!-- Tokyo Night Dialog Theme -->
    <style name="TokyoNightDialogTheme" parent="Theme.MaterialComponents.Dialog.Alert">
        <!-- Force Dark Scheme Colors -->
        <item name="colorSurface">#1a1b26</item>
        <item name="colorOnSurface">#c0caf5</item>
        
        <!-- Text Colors -->
        <item name="android:textColor">#c0caf5</item>
        <item name="android:textColorPrimary">#c0caf5</item>
        <item name="android:textColorSecondary">#a9b1d6</item>
        
        <!-- Dialog Background (Important) -->
        <item name="android:background">#1a1b26</item>
        
        <!-- Buttons -->
        <item name="colorPrimary">#7aa2f7</item>
        <item name="colorOnPrimary">#1a1b26</item>
        
        <!-- Button Styles -->
        <item name="buttonBarPositiveButtonStyle">@style/TokyoNightDialogButton</item>
        <item name="buttonBarNegativeButtonStyle">@style/TokyoNightDialogButton</item>
        <item name="buttonBarNeutralButtonStyle">@style/TokyoNightDialogButton</item>

        <!-- List Item Style (Crucial for setItems visibility) -->
        <item name="android:textColorAlertDialogListItem">#c0caf5</item>
    </style>

    <!-- Custom Button Style -->
    <style name="TokyoNightDialogButton" parent="Widget.MaterialComponents.Button.TextButton.Dialog">
        <item name="android:textColor">#7aa2f7</item>
    </style>
</resources>
