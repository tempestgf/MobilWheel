<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="horizontal"
    android:padding="24dp"
    android:background="@color/tokyo_bg"
    android:baselineAligned="false">

    <!-- Left Side: Branding -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:orientation="vertical"
        android:gravity="center"
        android:paddingEnd="24dp">

        <ImageView
            android:id="@+id/app_logo"
            android:layout_width="120dp"
            android:layout_height="120dp"
            android:src="@drawable/app_logo"
            android:layout_marginBottom="16dp"
            android:elevation="4dp"/>

        <TextView
            android:id="@+id/welcome_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Mobile Wheel"
            android:textSize="28sp"
            android:textColor="@color/tokyo_fg"
            android:fontFamily="sans-serif-medium"
            android:letterSpacing="0.05"
            android:layout_marginBottom="8dp"/>

        <TextView
            android:id="@+id/footer_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="© 2024 Tempestgf"
            android:textColor="@color/tokyo_gray"
            android:fontFamily="sans-serif"
            android:textSize="12sp" />
    </LinearLayout>

    <!-- Right Side: Buttons -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:orientation="vertical"
        android:gravity="center">

        <Button
            android:id="@+id/button_start"
            android:layout_width="280dp"
            android:layout_height="56dp"
            android:text="Start"
            android:textColor="@color/tokyo_bg"
            android:textAllCaps="false"
            android:textSize="18sp"
            android:fontFamily="sans-serif-medium"
            android:background="@drawable/tokyo_button"
            android:layout_marginBottom="16dp" 
            android:stateListAnimator="@null"
            android:elevation="0dp"/>

        <Button
            android:id="@+id/button_settings"
            android:layout_width="280dp"
            android:layout_height="56dp"
            android:text="Settings"
            android:textColor="@color/tokyo_fg"
            android:textAllCaps="false"
            android:textSize="18sp"
            android:fontFamily="sans-serif-medium"
            android:background="@drawable/tokyo_button_secondary"
            android:layout_marginBottom="16dp" 
            android:stateListAnimator="@null"
            android:elevation="0dp"/>

        <Button
            android:id="@+id/button_about"
            android:layout_width="280dp"
            android:layout_height="56dp"
            android:text="About"
            android:textColor="@color/tokyo_fg"
            android:textAllCaps="false"
            android:textSize="18sp"
            android:fontFamily="sans-serif-medium"
            android:background="@drawable/tokyo_button_secondary"
            android:stateListAnimator="@null"
            android:elevation="0dp"/>
    </LinearLayout>
</LinearLayout>
